@startuml PerFin_ClassDiagram
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classAttributeFontSize 11
skinparam linetype ortho
skinparam groupInheritance 2

title Sơ đồ Lớp (Class Diagram) - PerFin (Rolly)\nỨng dụng Quản lý Tài chính Cá nhân

' ===================================================================
' ENUMERATIONS
' ===================================================================

package "Enumerations" #FAFAFA {

    enum TransactionType {
        Expense
        Income
        Special
    }

    enum TransactionSource {
        text
        voice
        image
    }

    enum TransactionStatus {
        active
        softDeleted
        hardDeleted
    }

    enum CategoryType {
        Expense
        Income
    }

    enum WalletType {
        cash
        bank
        ewallet
        investment
    }

    enum BudgetPeriod {
        weekly
        monthly
    }

    enum ReminderFrequency {
        daily
        weekly
        monthly
        yearly
    }

    enum DebtType {
        lend
        borrow
    }

    enum DebtStatus {
        active
        paid
    }

    enum SharedWalletRole {
        admin
        member
    }

    enum ExportFormat {
        csv
        pdf
    }

    enum AILogType {
        input
        categorization
    }
}

' ===================================================================
' CORE ENTITIES
' ===================================================================

package "Người dùng & Xác thực" #E3F2FD {

    class User {
        + id : String <<PK>>
        + email : String <<unique>>
        + name : String
        + passwordHash : String
        + createdAt : DateTime
        --
        + register() : void
        + login() : void
        + updateProfile() : void
    }
}

package "Giao dịch" #E8F5E9 {

    class Transaction {
        + id : String <<PK>>
        + userId : String <<FK>>
        + name : String
        + amount : Decimal
        + type : TransactionType
        + categoryId : String <<FK>>
        + subCategoryId : String <<FK, nullable>>
        + walletId : String <<FK>>
        + date : DateTime
        + source : TransactionSource
        + status : TransactionStatus
        + aiConfidence : Float
        + attachmentUrl : String
        + createdAt : DateTime
        + deletedAt : DateTime
        --
        + create() : void
        + update() : void
        + softDelete() : void
        + hardDelete() : void
        + restore() : void
    }

    class Transfer {
        + id : String <<PK>>
        + fromWalletId : String <<FK>>
        + toWalletId : String <<FK>>
        + amount : Decimal
        + date : DateTime
        --
        + execute() : void
        + reverse() : void
    }
}

package "Danh mục" #FFF9C4 {

    class Category {
        + id : String <<PK>>
        + userId : String <<FK, nullable>>
        + name : String
        + type : CategoryType
        + isSystem : Boolean
        + createdAt : DateTime
        --
        + create() : void
        + update() : void
        + delete() : void
    }

    class SubCategory {
        + id : String <<PK>>
        + categoryId : String <<FK>>
        + name : String
        + createdAt : DateTime
        --
        + create() : void
        + update() : void
        + delete() : void
    }

    note right of Category
        Danh mục "Khác" là 
        danh mục hệ thống 
        bắt buộc (isSystem = true).
        Chỉ hỗ trợ 1 cấp danh mục con.
    end note
}

package "Ví / Tài khoản" #E0F7FA {

    class Wallet {
        + id : String <<PK>>
        + userId : String <<FK>>
        + name : String
        + type : WalletType
        + balance : Decimal
        + isDefault : Boolean
        + createdAt : DateTime
        --
        + create() : void
        + updateBalance() : void
        + setDefault() : void
    }
}

package "Ngân sách" #FFF3E0 {

    class Budget {
        + id : String <<PK>>
        + userId : String <<FK>>
        + categoryId : String <<FK, nullable>>
        + amount : Decimal
        + period : BudgetPeriod
        + startDate : DateTime
        + endDate : DateTime
        + rollover : Boolean
        + createdAt : DateTime
        --
        + create() : void
        + update() : void
        + checkProgress() : Float
        + applyRollover() : void
    }

    class BudgetAlert {
        + id : String <<PK>>
        + budgetId : String <<FK>>
        + threshold : Integer
        + isTriggered : Boolean
        + triggeredAt : DateTime
        --
        + trigger() : void
        + reset() : void
    }

    note right of BudgetAlert
        Ngưỡng cảnh báo mặc định:
        70%, 90%, 100%
    end note
}

package "Nhắc nhở" #F3E5F5 {

    class Reminder {
        + id : String <<PK>>
        + userId : String <<FK>>
        + transactionTemplate : JSON
        + frequency : ReminderFrequency
        + nextDueDate : DateTime
        + isActive : Boolean
        --
        + create() : void
        + update() : void
        + deactivate() : void
        + getNextDueDate() : DateTime
    }
}

package "Giao dịch đặc biệt" #FBE9E7 {

    class Debt {
        + id : String <<PK>>
        + userId : String <<FK>>
        + personName : String
        + amount : Decimal
        + type : DebtType
        + dueDate : DateTime
        + status : DebtStatus
        + relatedTransactionId : String <<FK, nullable>>
        --
        + create() : void
        + markAsPaid() : void
        + update() : void
    }

    class Savings {
        + id : String <<PK>>
        + userId : String <<FK>>
        + walletId : String <<FK>>
        + goalAmount : Decimal
        + currentAmount : Decimal
        + goalDate : DateTime
        --
        + create() : void
        + addContribution() : void
        + checkProgress() : Float
    }

    class Investment {
        + id : String <<PK>>
        + userId : String <<FK>>
        + walletId : String <<FK>>
        + type : String
        + initialAmount : Decimal
        + currentValue : Decimal
        + profitLoss : Decimal
        --
        + create() : void
        + updateValue() : void
        + calculateProfitLoss() : Decimal
    }
}

package "AI & Nhân cách" #EDE7F6 {

    class AILog {
        + id : String <<PK>>
        + userId : String <<FK>>
        + transactionId : String <<FK, nullable>>
        + originalResult : JSON
        + correctedResult : JSON
        + logType : AILogType
        + isAnonymized : Boolean
        + createdAt : DateTime
        --
        + create() : void
        + anonymize() : void
    }

    class AIPersonality {
        + id : String <<PK>>
        + name : String
        + description : String
        + tone : String
        + isDefault : Boolean
        --
        + create() : void
        + update() : void
        + activate() : void
    }

    class UserHabit {
        + id : String <<PK>>
        + userId : String <<FK>>
        + habitType : String
        + habitData : JSON
        + isApproved : Boolean
        + createdAt : DateTime
        --
        + create() : void
        + approve() : void
        + reject() : void
    }
}

package "Cộng tác" #E0F2F1 {

    class SharedWallet {
        + id : String <<PK>>
        + name : String
        + createdBy : String <<FK>>
        + createdAt : DateTime
        --
        + create() : void
        + addMember() : void
        + removeMember() : void
    }

    class SharedWalletMember {
        + id : String <<PK>>
        + sharedWalletId : String <<FK>>
        + userId : String <<FK>>
        + role : SharedWalletRole
        + joinedAt : DateTime
        --
        + join() : void
        + changeRole() : void
        + leave() : void
    }
}

package "Xuất & Sao lưu" #F1F8E9 {

    class ExportJob {
        + id : String <<PK>>
        + userId : String <<FK>>
        + format : ExportFormat
        + filters : JSON
        + status : String
        + fileUrl : String
        + createdAt : DateTime
        --
        + start() : void
        + complete() : void
        + getFile() : String
    }

    class BackupJob {
        + id : String <<PK>>
        + userId : String <<FK>>
        + status : String
        + fileUrl : String
        + isAutomatic : Boolean
        + createdAt : DateTime
        --
        + start() : void
        + complete() : void
        + restore() : void
    }
}

' ===================================================================
' RELATIONSHIPS
' ===================================================================

' --- User owns many entities ---
User "1" --o "0..*" Transaction : "sở hữu >"
User "1" --o "0..*" Category : "tạo >"
User "1" --o "0..*" Wallet : "sở hữu >"
User "1" --o "0..*" Budget : "thiết lập >"
User "1" --o "0..*" Reminder : "tạo >"
User "1" --o "0..*" Debt : "quản lý >"
User "1" --o "0..*" Savings : "quản lý >"
User "1" --o "0..*" Investment : "quản lý >"
User "1" --o "0..*" AILog : "ghi nhận >"
User "1" --o "0..*" UserHabit : "có >"
User "1" --o "0..*" ExportJob : "yêu cầu >"
User "1" --o "0..*" BackupJob : "yêu cầu >"
User "1" -- "0..1" AIPersonality : "chọn nhân cách >"

' --- Transaction relationships ---
Transaction "0..*" --> "1" Category : "thuộc danh mục >"
Transaction "0..*" --> "0..1" SubCategory : "thuộc danh mục con >"
Transaction "0..*" --> "1" Wallet : "từ ví >"

' --- Category - SubCategory ---
Category "1" --o "0..*" SubCategory : "chứa >"

' --- Budget relationships ---
Budget "0..*" --> "0..1" Category : "theo danh mục >"
Budget "1" --o "1..*" BudgetAlert : "có cảnh báo >"

' --- Transfer relationships ---
Transfer "0..*" --> "1" Wallet : "từ ví nguồn >"
Transfer "0..*" --> "1" Wallet : "đến ví đích >"

' --- Special transactions ---
Debt "0..*" --> "0..1" Transaction : "liên kết giao dịch >"
Savings "0..*" --> "1" Wallet : "liên kết ví >"
Investment "0..*" --> "1" Wallet : "liên kết ví >"

' --- AI relationships ---
AILog "0..*" --> "0..1" Transaction : "ghi nhận cho >"

' --- SharedWallet relationships ---
SharedWallet "1" --o "1..*" SharedWalletMember : "có thành viên >"
SharedWallet "0..*" --> "1" User : "tạo bởi >"
SharedWalletMember "0..*" --> "1" User : "là >"

' ===================================================================
' LEGEND
' ===================================================================

legend bottom right
    |= Ký hiệu |= Ý nghĩa |
    | --o | Composition (sở hữu) |
    | --> | Association (liên kết) |
    | <<PK>> | Primary Key |
    | <<FK>> | Foreign Key |
    | 1..* | Một hoặc nhiều |
    | 0..* | Không hoặc nhiều |
    | 0..1 | Không hoặc một |
endlegend

@enduml
