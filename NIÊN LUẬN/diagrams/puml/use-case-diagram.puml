@startuml
left to right direction
skinparam packageStyle rectangle

actor "Người dùng (User)" as User
actor "AI Engine" as AI
actor "Quản trị viên (Admin)" as Admin
actor "Hệ thống (System)" as System

rectangle "Rolly - Quản lý Tài chính Thông minh" {
  usecase "Ghi chép giao dịch\n(Text/Voice/Image)" as UC1
  usecase "Phân loại tự động\n(Auto-Categorization)" as UC2
  usecase "Quản lý ngân sách\n(Budget)" as UC3
  usecase "Xem báo cáo & Phân tích" as UC4
  usecase "Quản lý đa ví\n(Multi-Account)" as UC5
  usecase "Nhắc nhở & Lập lịch" as UC6
  usecase "Xuất dữ liệu & Sao lưu" as UC7
  usecase "Xác thực & Bảo mật" as UC8
  usecase "Đổi nhân cách AI" as UC9
  usecase "Quản lý ví dùng chung" as UC10
  
  usecase "Sinh AI Insight" as UC11
  usecase "Cảnh báo vượt ngân sách" as UC12
}

User --> UC1
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC9
User --> UC10

AI --> UC2
AI --> UC11

System --> UC12
System --> UC7
System --> UC6

UC1 .> UC2 : <<include>>
UC4 .> UC11 : <<extend>>
UC3 .> UC12 : <<extend>>

@enduml
